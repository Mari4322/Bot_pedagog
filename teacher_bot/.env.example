BOT_TOKEN=
POLZA_API_KEY=
ADMIN_TG_ID=
DB_PATH=database/bot.db
TZ=Asia/Novosibirsk

# Порог баланса polza.ai в рублях — при падении ниже шлём предупреждение админу
BALANCE_THRESHOLD=100

# --- Этап 2: Продамус ---
# Секретный ключ для проверки подписи вебхука (из личного кабинета Продамуса)
PRODAMUS_SECRET_KEY=
# Публичный HTTPS-URL вашего сервера (нужен домен + SSL)
# Пример: https://your-domain.ru
WEBHOOK_URL=
# Порт, на котором слушает FastAPI (по умолчанию 8080)
WEBHOOK_PORT=8080

# --- Этап 3: S3-бэкапы (Beget) ---
# Эндпоинт S3
S3_ENDPOINT=https://s3.ru1.storage.beget.cloud
# Имя бакета
S3_BUCKET=
# Ключи доступа (из панели Beget → S3 → Ключи доступа)
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Папка внутри бакета (по умолчанию backups/)
S3_PREFIX=backups/
